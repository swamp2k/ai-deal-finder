{
	"$schema": "node_modules/wrangler/config-schema.json",
	"main": ".open-next/worker.js",
	"name": "ai-deal-finder",
	"compatibility_date": "2026-06-12",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"assets": {
		"directory": ".open-next/assets",
		"binding": "ASSETS"
	},
	"rules": [
		{ "type": "ESModule", "globs": ["**/*.mjs"] },
		{ "type": "CommonJS", "globs": ["**/*.cjs"] },
		{ "type": "Data", "globs": ["**/*.wasm", "**/*.sql"] }
	]
}